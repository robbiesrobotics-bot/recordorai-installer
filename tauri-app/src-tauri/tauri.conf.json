{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RecordorAI Installer",
  "version": "0.1.0",
  "identifier": "com.recordorai.installer",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "RecordorAI Installer",
        "width": 880,
        "height": 640,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "RecordorAI",
    "shortDescription": "Local-first AI memory installer",
    "longDescription": "Cross-platform installer for RecordorAI — give your AI a memory. Configures the user's chosen agent runtime (Standalone, OpenClaw, pi-mono, Alice-runtime, or Hermes Agent).",
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": []
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "deb": {
        "depends": ["python3 (>= 3.9)"]
      }
    }
  },
  "plugins": {}
}
