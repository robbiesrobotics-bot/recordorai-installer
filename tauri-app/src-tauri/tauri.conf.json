{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RecordorAI Installer",
  "version": "0.1.0",
  "identifier": "com.recordorai.installer",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "RecordorAI Installer",
        "width": 880,
        "height": 640,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "nsis", "appimage", "deb", "rpm"],
    "externalBin": [
      "binaries/recordorai-install"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "RecordorAI",
    "shortDescription": "Local-first AI memory installer",
    "longDescription": "Cross-platform installer for RecordorAI — give your AI a memory. Configures the user's chosen agent runtime (Standalone, OpenClaw, pi-mono, Alice-runtime, or Hermes Agent).",
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": [],
      "signingIdentity": "$APPLE_SIGNING_IDENTITY",
      "providerShortName": "$APPLE_PROVIDER_SHORT_NAME",
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      },
      "certificateThumbprint": "$WINDOWS_CERTIFICATE_THUMBPRINT",
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/RecordorAI/recordorai-installer/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "$TAURI_UPDATER_PUBKEY"
    }
  }
}
